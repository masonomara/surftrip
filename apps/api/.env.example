# =============================================================================
# API Development Environment Variables
# =============================================================================
# Copy to .dev.vars and fill in values

ENVIRONMENT=development

# -----------------------------------------------------------------------------
# Cloudflare (required for wrangler dev and integration tests)
# -----------------------------------------------------------------------------
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# -----------------------------------------------------------------------------
# Better Auth (required)
# -----------------------------------------------------------------------------
BETTER_AUTH_URL=http://localhost:8787
BETTER_AUTH_SECRET=           # Generate: openssl rand -base64 32

# -----------------------------------------------------------------------------
# Encryption (required - for Clio OAuth tokens)
# -----------------------------------------------------------------------------
ENCRYPTION_KEY=               # Generate: openssl rand -base64 32

# -----------------------------------------------------------------------------
# Clio OAuth (required - get from Clio developer portal)
# -----------------------------------------------------------------------------
CLIO_APP_ID=
CLIO_CLIENT_ID=
CLIO_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Google SSO (optional)
# -----------------------------------------------------------------------------
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Apple SSO (optional)
# -----------------------------------------------------------------------------
# APPLE_KEY_ID=
# APPLE_TEAM_ID=
# APPLE_CLIENT_ID=
# APPLE_CLIENT_SECRET=
# APPLE_APP_BUNDLE_IDENTIFIER=

# -----------------------------------------------------------------------------
# Email (optional - for transactional emails)
# -----------------------------------------------------------------------------
# RESEND_API_KEY=

# -----------------------------------------------------------------------------
# Knowledge Base Seeding (optional)
# -----------------------------------------------------------------------------
# SEED_SECRET=
